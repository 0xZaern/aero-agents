# Backend API base URL used by the dev/prod rewrite proxy in next.config.ts.
# Same-origin "/api/..." calls are forwarded here.
BACKEND_URL=http://localhost:8000

# Optional: call the backend directly (bypassing the rewrite proxy) for REST.
# Leave unset to use same-origin "/api/...". WebSockets always use this.
NEXT_PUBLIC_API_URL=

# Public site URL (used for absolute links / OG metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3002
