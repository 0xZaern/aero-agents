# LLM gateway API (OpenAI-compatible)
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://your-llm-gateway.example/v1

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.yourproject.supabase.co:5432/postgres

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=https://yourdomain.com

# Defaults
DEFAULT_MODEL=claude-sonnet-4-6
MAX_CONVERSATION_MESSAGES=100

# JWT
JWT_SECRET=generate_a_random_64_char_string

# Payments (USDC on Base chain)
TREASURY_WALLET=your_wallet_address
USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BASE_RPC_URL=https://mainnet.base.org
PRO_PRICE_USD=80

# Backend URL (used by telegram bot - set automatically in Docker via docker-compose)
# In Docker: http://backend:8000  |  Local dev: http://localhost:8000
BACKEND_URL=http://localhost:8000

# Legitimacy Analyzer
TWITTERAPI_IO_KEY=your_twitterapi_io_key
LEGITIMACY_ANALYZER_ENABLED=false

# Frontend - Legitimacy Analyzer mock mode (dev only, no backend needed)
# VITE_LEGITIMACY_MOCK=true

# GitHub Analyzer
# Classic PAT, no scopes needed for public repos. 5000 req/hr with token vs 60/hr without.
# Create at github.com/settings/tokens → "Generate new token (classic)" → leave all scopes unchecked
GITHUB_TOKEN=your_github_classic_pat
GITHUB_ANALYZER_ENABLED=false

NEXT_PUBLIC_SITE_URL=https://aeroagents.io

# WalletConnect / Reown Cloud project id (PUBLIC - ships in the client bundle).
# Optional: a default is baked into the connect modal. Override here or in Vercel
# env vars. Make a free dedicated one at https://cloud.reown.com if desired.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=0d3e11c77e6d60dc7e069d27c7ccbac5
